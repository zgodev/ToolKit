<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/common_color_bg"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="80dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/login_welcome"
        android:textColor="?attr/common_color_text_main"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etAccount"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="40dp"
        android:hint="@string/login_hint_account"
        android:inputType="text"
        android:background="@drawable/login_bg_input"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="?attr/common_color_text_main"
        android:textColorHint="#FFCCCCCC"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:hint="@string/login_hint_password"
        android:inputType="textPassword"
        android:background="@drawable/login_bg_input"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="?attr/common_color_text_main"
        android:textColorHint="#FFCCCCCC"
        app:layout_constraintTop_toBottomOf="@id/etAccount"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:text="@string/login_btn_login"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:background="@drawable/login_bg_button"
        app:layout_constraintTop_toBottomOf="@id/etPassword"/>

    <TextView
        android:id="@+id/tvTip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/login_tip"
        android:textColor="?attr/common_color_text_sub"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/btnLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

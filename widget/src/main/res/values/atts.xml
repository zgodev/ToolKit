<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TitleBar">
        <attr name="widget_title" format="string"/>
    </declare-styleable>

    <declare-styleable name="NodeProgressBar">
        <attr name="progress" format="integer"/>
        <attr name="max" format="integer"/>
        <attr name="primaryNodeColor" format="color"/>
        <attr name="secondaryNodeColor" format="color"/>
        <attr name="nodeRadius" format="dimension"/>
        <attr name="secondaryNodeRadius" format="dimension"/>
        <attr name="labelTextSize" format="dimension"/>
        <attr name="labelTextColor" format="color"/>
        <attr name="progressBarHeight" format="dimension"/>
        <attr name="progressColor" format="color"/>
        <attr name="trackColor" format="color"/>
    </declare-styleable>
</resources>